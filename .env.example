# Environment
OPENAI_API_KEY=
# Optional: Qwen via Alibaba Cloud OpenAI-compatible endpoint
DASHSCOPE_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
IMGGPT_BACKEND_HOST=127.0.0.1
IMGGPT_BACKEND_PORT=8000
IMGGPT_DB_PATH=backend/data/imagegpt.db
IMGGPT_RECIPES_DIR=backend/data/recipes
IMGGPT_PRESETS_DIR=backend/data/presets
IMGGPT_EXPORT_DIR=backend/data/exports
IMGGPT_ENABLE_TELEMETRY=false
IMGGPT_LOG_LEVEL=INFO
IMGGPT_JPEG_QUALITY=92
IMGGPT_PREVIEW_MAX_EDGE=1536
